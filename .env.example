# =============================================================================
# Kolmogorov's team — Systematic Equity Pipeline
# Environment Variables Template
# Copy this file to .env.dev and fill in your credentials.
# =============================================================================

# --- MinIO (Object Storage) ---
MINIO_USER=ift_bigdata
MINIO_PASSWORD=minio_password
MINIO_URL=http://localhost:9000

# --- PostgreSQL ---
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_DEV=localhost
POSTGRES_PORT_DEV=5438
POSTGRES_HOST_DOCKER=postgres_db
POSTGRES_PORT_DOCKER=5432
POSTGRES_DATABASE=fift

# --- MongoDB ---
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USERNAME=ift_bigdata
MONGO_PASSWORD=mongo_password

# --- Apache Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Finnhub (optional – for non-US fundamental supplements) ---
FINNHUB_API_KEY=your_finnhub_api_key_here

# --- Refinitiv / LSEG Data Platform (ESG scores — no desktop app required) ---
# Credentials from your LSEG/Refinitiv account (platform session via REST API).
REFINITIV_USERNAME=your_email@example.com
REFINITIV_PASSWORD=your_refinitiv_password
REFINITIV_APP_KEY=your_refinitiv_app_key_here

# --- NewsAPI (secondary news source — gap-fill when yfinance returns 0) ---
# Free tier: 100 requests/day. Get your key at https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# --- Alpha Vantage (non-US fundamentals supplement — fallback order) ---
# Free tier: 25 requests/day per key. Only KEY_1 is required.
# Additional keys are optional fallbacks — when KEY_1 is rate-limited,
# KEY_2 takes over automatically, and so on. More keys = more daily quota.
# Get free keys at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY_1=your_alpha_vantage_key
# ALPHA_VANTAGE_KEY_2=optional_second_key
# ALPHA_VANTAGE_KEY_3=optional_third_key

# --- Financial Modeling Prep (non-US fundamentals supplement) ---
# Free tier: 250 requests/day. Get your key at https://financialmodelingprep.com
FMP_API_KEY=your_fmp_api_key_here

# --- SimFin (non-US fundamentals supplement — bulk financial data) ---
# Free tier: 2000 requests/day. Get your key at https://simfin.com
SIMFIN_API_KEY=your_simfin_api_key_here
